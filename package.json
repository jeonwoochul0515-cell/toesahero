{
  "name": "toesahero",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite-react-ssg dev",
    "typecheck:functions": "tsc -p functions/tsconfig.json --noEmit",
    "test": "vitest run",
    "build": "tsc -b && npm run typecheck:functions && vite-react-ssg build",
    "preview": "vite preview",
    "deploy": "npm run build && firebase deploy --only hosting",
    "blog:seed": "node scripts/seed-posts.mjs",
    "blog:publish-daily": "node scripts/auto-publish-daily.mjs"
  },
  "dependencies": {
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "firebase": "^10.14.1",
    "pretendard": "^1.3.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.4",
    "remark-gfm": "^4.0.1",
    "vite-react-ssg": "^0.9.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260613.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.8"
  }
}
