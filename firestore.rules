rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 익명 사용자가 상담 요청을 생성할 수 있게 허용 (읽기/수정/삭제는 어드민만)
    match /consultations/{docId} {
      allow create: if request.resource.data.keys().hasAll(['source', 'createdAt'])
                    && request.resource.data.source in ['chat', 'form', 'floating'];
      allow read, update, delete: if false;
    }
    match /chat_messages/{docId} {
      allow create: if request.resource.data.keys().hasAll(['text', 'role', 'createdAt'])
                    && request.resource.data.role in ['me', 'them'];
      allow read, update, delete: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
