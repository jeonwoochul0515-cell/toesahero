rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // 익명/카카오/이메일 로그인 사용자 모두 상담 요청 생성 가능.
    // 어드민만 읽기/수정/삭제 가능.
    match /consultations/{docId} {
      allow create: if request.resource.data.keys().hasAll(['source', 'createdAt'])
                    && request.resource.data.source in ['chat', 'form', 'floating', 'draft']
                    && (
                      !('uid' in request.resource.data)
                      || request.resource.data.uid == null
                      || request.resource.data.uid == request.auth.uid
                    );
      allow read: if isAdmin();
      allow update: if isAdmin()
                    && request.resource.data.diff(resource.data)
                       .affectedKeys()
                       .hasOnly(['status', 'notes', 'updatedAt', 'assignedTo', 'draftLetter', 'draftStatus', 'draftApprovedAt']);
      allow delete: if isAdmin();
    }

    // 채팅 메시지 로그.
    match /chat_messages/{docId} {
      allow create: if request.resource.data.keys().hasAll(['text', 'role', 'createdAt'])
                    && request.resource.data.role in ['me', 'them']
                    && (
                      !('uid' in request.resource.data)
                      || request.resource.data.uid == null
                      || request.resource.data.uid == request.auth.uid
                    );
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // 어드민 식별 컬렉션.
    match /admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // 후기. 어드민만 작성/수정/삭제. 공개(approved + display=true)는 누구나 읽기.
    match /reviews/{docId} {
      allow read: if isAdmin()
                  || (resource.data.status == 'approved' && resource.data.display == true);
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
