rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 익명/카카오 로그인 사용자 모두 상담 요청 생성 가능. uid 필드는 있다면 본인 것이어야 함.
    match /consultations/{docId} {
      allow create: if request.resource.data.keys().hasAll(['source', 'createdAt'])
                    && request.resource.data.source in ['chat', 'form', 'floating']
                    && (
                      !('uid' in request.resource.data)
                      || request.resource.data.uid == null
                      || request.resource.data.uid == request.auth.uid
                    );
      allow read, update, delete: if false;
    }
    match /chat_messages/{docId} {
      allow create: if request.resource.data.keys().hasAll(['text', 'role', 'createdAt'])
                    && request.resource.data.role in ['me', 'them']
                    && (
                      !('uid' in request.resource.data)
                      || request.resource.data.uid == null
                      || request.resource.data.uid == request.auth.uid
                    );
      allow read, update, delete: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
