VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# 토스페이먼츠 (가맹 등록 후 발급)
VITE_TOSS_CLIENT_KEY=
# 서버 사이드 (CF Pages env vars 에 등록, GitHub Secret 아님)
# TOSS_SECRET_KEY=

# 서버 측 Firestore 쓰기용 서비스계정 (결제 결과 반영) — CF Pages env vars 에만
# Firebase 콘솔 → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성 → JSON 전체를 한 줄로 붙여넣기
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# FIREBASE_PROJECT_ID=  ← 생략 시 서비스계정의 project_id 사용

# SOLAPI (이벤트 문자 알림) — CF Pages env vars 에만
# SOLAPI_API_KEY=
# SOLAPI_API_SECRET=
# SOLAPI_SENDER=     ← SOLAPI 에 사전 등록된 발신번호 (예: 16604452)
# ALERT_TO_PHONE=    ← 알림 받을 변호사 휴대폰 번호

# Resend (이메일 발송)
# RESEND_API_KEY=  ← CF Pages env vars에 등록
# RESEND_FROM_EMAIL=
# RESEND_BCC_EMAIL=

# Anthropic (AI 챗봇)
# ANTHROPIC_API_KEY=  ← CF Pages env vars에 등록
